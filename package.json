{
   "name": "facility-management-ui",
   "version": "0.1.0",
   "private": true,
   "scripts": {
      "dev": "next dev",
      "build": "next build",
      "start": "next start",
      "lint": "next lint"
   },
   "dependencies": {
      "classnames": "^2.5.1",
      "formsy-react": "^2.3.2",
      "next": "15.2.4",
      "react": "^19.0.0",
      "react-dom": "^19.0.0"
   },
   "devDependencies": {
      "@eslint/eslintrc": "^3",
      "@svgr/webpack": "^8.1.0",
      "@tailwindcss/postcss": "^4",
      "@types/node": "^20",
      "@types/react": "^19",
      "@types/react-dom": "^19",
      "eslint": "^9",
      "eslint-config-next": "15.2.4",
      "prettier": "^3.5.3",
      "tailwindcss": "^4",
      "typescript": "^5"
   },
   "eslintConfig": {
      "extends": [
         "react-app",
         "react-app/jest",
         "prettier"
      ],
      "plugins": [
         "prettier"
      ],
      "rules": {
         "prettier/prettier": [
            "warn",
            {
               "endOfLine": "auto",
               "bracketSpacing": false,
               "jsxBracketSameLine": true,
               "singleQuote": true,
               "trailingComma": "all",
               "tabWidth": 3,
               "printWidth": 150
            }
         ]
      }
   }
}
