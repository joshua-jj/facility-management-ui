{
   "name": "facility-management-ui",
   "version": "0.1.0",
   "private": true,
   "scripts": {
      "dev": "next dev",
      "build": "next build",
      "start": "next start",
      "lint": "next lint",
      "docker:dev": "docker-compose up --build",
      "docker:prod": "docker-compose -f docker-compose.prod.yml up --build",
      "docker:stop": "docker-compose down --volumes",
      "docker:logs": "docker-compose logs -f",
      "docker:exec": "docker-compose exec -it facility-management-ui sh",
      "docker:exec-prod": "docker-compose -f docker-compose.prod.yml exec -it facility-management-ui sh",
      "prettier": "prettier --write ."
   },
   "dependencies": {
      "@reduxjs/toolkit": "^2.6.1",
      "axios": "^1.8.4",
      "chart.js": "^4.4.9",
      "class-variance-authority": "^0.7.1",
      "classnames": "^2.5.1",
      "clsx": "^2.1.1",
      "date-fns": "^4.1.0",
      "dayjs": "^1.11.13",
      "formsy-react": "^2.3.2",      "framer-motion": "^12.38.0",
      "js-cookie": "^3.0.5",
      "localforage": "^1.10.0",
      "next": "15.2.8",
      "next-redux-wrapper": "^8.1.0",
      "nookies": "^2.5.2",
      "react": "^19.0.0",
      "react-chartjs-2": "^5.3.0",
      "react-dom": "^19.0.0",
      "react-redux": "^9.2.0",
      "recharts": "^3.8.1",
      "redux": "^5.0.1",
      "redux-persist": "^6.0.0",
      "redux-saga": "^1.3.0",
      "tailwind-merge": "^3.5.0",
      "typed-redux-saga": "^1.5.0",
      "xlsx": "^0.18.5"
   },
   "devDependencies": {
      "@eslint/eslintrc": "^3",
      "@svgr/webpack": "^8.1.0",
      "@tailwindcss/postcss": "^4",
      "@types/chart.js": "^2.9.41",
      "@types/js-cookie": "^3.0.6",
      "@types/node": "^20",
      "@types/react": "^19",
      "@types/react-dom": "^19",
      "eslint": "^9",
      "eslint-config-next": "15.2.4",
      "prettier": "^3.5.3",
      "tailwindcss": "^4",
      "typescript": "^5"
   },
   "eslintConfig": {
      "extends": [
         "react-app",
         "react-app/jest",
         "prettier"
      ],
      "plugins": [
         "prettier"
      ],
      "rules": {
         "prettier/prettier": [
            "warn",
            {
               "endOfLine": "auto",
               "bracketSpacing": false,
               "jsxBracketSameLine": true,
               "singleQuote": true,
               "trailingComma": "all",
               "tabWidth": 3,
               "printWidth": 150
            }
         ]
      }
   },
   "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
